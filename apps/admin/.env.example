# Base URL of the Hajj Platform backend (NestJS). The admin's own API routes
# proxy all client traffic to this URL server-side, which is how we keep the
# access token in an httpOnly cookie (the browser never sees it).
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Shown in the login card + browser tab title.
NEXT_PUBLIC_APP_NAME=Mubarak Travels Admin

# development | production | test — gates the React Query devtools, logger
# verbosity, and Secure cookie flag.
NODE_ENV=development
