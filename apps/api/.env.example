DATABASE_URL=postgresql://hajj:devonly@localhost:5432/hajj_dev
TEST_DATABASE_URL=postgresql://hajj:devonly@localhost:5432/hajj_test
REDIS_URL=redis://localhost:6379
# REPLACE_BEFORE_PRODUCTION - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_BEFORE_PRODUCTION_64_char_hex
# REPLACE_BEFORE_PRODUCTION - MUST differ from JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=REPLACE_BEFORE_PRODUCTION_64_char_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug
