# Runtime
NODE_ENV=development
PORT=3000

# Database (Postgres 16)
DATABASE_URL=postgresql://hajj:devonly@localhost:5432/hajj_dev

# Cache (Redis 7)
REDIS_URL=redis://localhost:6379

# Auth (JWT) — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Cloudflare R2 object storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# Observability
SENTRY_DSN=
